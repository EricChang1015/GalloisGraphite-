# ====================================================================
# Mada Graphite Platform — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# .env* are gitignored except for this `.env.example`.
# ====================================================================

# ---------- Supabase --------------------------------------------------
# Dashboard → Project Settings → API
# 在 Supabase Dashboard → Project Settings → API 找到這些值
# Project URL 格式: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
# 只能在 Server (Server Action / Route Handler) 使用,絕不可進 Client Component
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx

#
# 你的 Supabase project URL (供參考,不用填進這裡):
# https://ihobyifetbctlqvknxem.supabase.co
# Direct connection (Prisma / 本地工具用,本平台不使用 Prisma):
# postgresql://postgres:[YOUR-PASSWORD]@db.ihobyifetbctlqvknxem.supabase.co:5432/postgres

# ---------- AI 助手 (via POE API — OpenAI-compatible) -----------------
# https://poe.com/api_key
# POE 支援透過同一個 key 呼叫不同 model:
#   Claude:  claude-3-5-sonnet  / claude-3-7-sonnet  / claude-3-opus
#   OpenAI:  gpt-4o / gpt-4o-mini / gpt-5.4-mini
#   Gemini:  gemini-2.0-flash / gemini-2.0-pro
#   Llama:   llama-3.1-405b-instruct
# 更多 model list: https://poe.com/explore?category=Official
POE_API_KEY=your_poe_key_here
POE_MODEL=claude-3-5-sonnet
# POE base URL (OpenAI-compatible endpoint)
POE_BASE_URL=https://api.poe.com/v1

# ---------- Resend (Email) -------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# 寄件人 email(domain 需先在 Resend Dashboard 完成 DNS 驗證)
RESEND_FROM_EMAIL=noreply@madagraphite.com
RESEND_FROM_NAME=Mada Graphite

# ---------- App ------------------------------------------------------
# 部署後請填正式網址,例如 https://mada-graphite.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 站內中介 (verify email 等) 連結用
NEXT_PUBLIC_APP_NAME="Mada Graphite"

# ---------- 平台收款資訊(顯示用,給買家在訂單頁參考) ----------------
PLATFORM_USDT_TRC20_ADDRESS=Txxxxxxxxxxxxxxxxxxxxxxxx
PLATFORM_USDT_ERC20_ADDRESS=0xxxxxxxxxxxxxxxxxxxxxxxxxxx
PLATFORM_USDI_ADDRESS=
PLATFORM_MUP_ADDRESS=
# 銀行轉帳資訊(多行可用 \n 分隔,或在 UI 端用 textarea)
PLATFORM_BANK_INFO="Bank: XXX Bank | Account: 0000-0000-0000 | SWIFT: XXXXXX | Beneficiary: Graphite Energy Inc."

# ---------- Feature Flags --------------------------------------------
# 是否開放賣家自助上貨(MVP 期間可設為 false,只允許 admin 邀請的賣家)
NEXT_PUBLIC_ENABLE_SELLER_SELF_SIGNUP=true
NEXT_PUBLIC_ENABLE_AI_CHAT=true

# ---------- 備用 AI (可選) -------------------------------------------
# 如果日後有 Anthropic 直接帳號,可同時保留:
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
