# Server runtime env for mada-next container (gitignored as .env on VM).
# Generated by: npm run deploy:uat:next

NODE_ENV=production
NEXT_PUBLIC_SUPABASE_URL=https://uat.gf-v.io
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://uat.gf-v.io
NEXT_PUBLIC_APP_NAME=Mada Graphite

POE_API_KEY=
POE_MODEL=claude-3-5-sonnet
POE_BASE_URL=https://api.poe.com/v1

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM_DOMAIN=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=

ADMIN_EMAIL=
CRON_SECRET=

PLATFORM_USDT_TRC20_ADDRESS=
PLATFORM_USDT_ERC20_ADDRESS=
PLATFORM_USDI_ADDRESS=
PLATFORM_MUP_ADDRESS=
PLATFORM_BANK_INFO=

NEXT_PUBLIC_ENABLE_SELLER_SELF_SIGNUP=true
NEXT_PUBLIC_ENABLE_AI_CHAT=true
