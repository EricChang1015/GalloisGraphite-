# Copy to /data/deploy/supabase/.env.uat on the UAT server (gitignored).
# Applied on top of upstream/.env by bootstrap.sh
# Prefer: npm run deploy:uat:oauth (merges from .env.local automatically)

############
# Public URLs (Phase 2: Next.js + Supabase same origin)
############
SUPABASE_PUBLIC_URL=https://uat.gf-v.io
API_EXTERNAL_URL=https://uat.gf-v.io
SITE_URL=https://uat.gf-v.io
ADDITIONAL_REDIRECT_URLS=https://uat.gf-v.io/auth/callback,http://localhost:3000/auth/callback

############
# Google OAuth (GoTrue — also set in .env.local for deploy scripts)
# Google Console redirect URI: https://uat.gf-v.io/auth/v1/callback
############
GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

############
# Kong — localhost only (Nginx terminates TLS)
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# Studio
############
STUDIO_DEFAULT_ORGANIZATION=Mada Graphite
STUDIO_DEFAULT_PROJECT=UAT

############
# Auth email — fill SMTP from AWS SES (same as Next.js app)
############
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Mada Graphite

############
# Storage
############
GLOBAL_S3_BUCKET=stub
STORAGE_TENANT_ID=stub
REGION=stub
